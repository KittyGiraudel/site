---
layout: page
---

{% render "styles.liquid",
  inline: site.configuration.inline_assets,
  partials: "
    components/title,
    components/figure,
    components/code,
    components/tags,
    components/collection-navigation,
    pages/project
  "
%}

<article class="Project">
  <section class="Project__header">
    <p class="Project__description">
      {{ description }}
    </p>

    <div class="Project__tags">
      {% render "tags.liquid", tags: tags %}
    </div>

    <div class="Project__meta" aria-label="Project links">
      {% if website %}
        <a class="Project__meta-link" href="{{ website }}" target="_blank" rel="noopener noreferrer">
          Visit website
        </a>
      {% endif %}

      {% assign project_stars = github.stargazers[repository] | default: 0 %}
      <a class="Project__meta-link" href="{{ repository }}" target="_blank" rel="noopener noreferrer">
        View on GitHub
        {% if project_stars > 0 %}
          <span class="Project__stars">
            · {{ project_stars }} ★
          </span>
        {% endif %}
      </a>
    </div>
  </section>

  {% if image %}
    <figure class="Figure">
      <img
        src="{{ image }}"
        alt="{{ title }}"
        loading="eager"
        style="view-transition-name: {{ page.url | slugify }}"
      >
      {% if image_caption %}
        <figcaption>
          {{ image_caption }}
        </figcaption>
      {% endif %}
    </figure>
  {% endif %}

  <section class="Project__content">
    {% markdown %}
      {{ content }}
    {% endmarkdown %}
  </section>
</article>

{% render "collection_navigation.liquid",
  page: page,
  collection: collections.projects,
  label: "project",
  dev_mode: site.configuration.dev_mode
%}
