---
layout: page
---

{% render "styles.liquid",
  inline: site.configuration.inline_assets,
  partials: "
    components/title,
    components/figure,
    components/code,
    components/tags,
    components/tile,
    components/collection-navigation,
    pages/project
  "
%}

{% assign project = projects | where: "name", project_name | first %}

<article class="Project">
  <section class="Project__header">
    {% if project %}
      <p class="Project__description">
        {{ project.description }}
      </p>

      {% if project.tags %}
        <div class="Project__tags">
          {% render "tags.liquid", tags: project.tags %}
        </div>
      {% endif %}
    {% endif %}

    <div class="Project__meta" aria-label="Project links">
      {% if project and project.link %}
        <a class="Project__meta-link" href="{{ project.link }}" target="_blank" rel="noopener noreferrer">
          Visit website
        </a>
      {% endif %}

      {% if project and project.repository %}
        {% assign project_stars = github.stargazers[project.repository] | default: 0 %}
        <a class="Project__meta-link" href="{{ project.repository }}" target="_blank" rel="noopener noreferrer">
          View on GitHub
          {% if project_stars > 0 %}
            <span class="Project__stars">
              · {{ project_stars }} ★
            </span>
          {% endif %}
        </a>
      {% endif %}
    </div>
  </section>

  {% if screenshot %}
    <figure class="Figure">
      <img
        src="{{ screenshot }}"
        alt="{{ screenshot_alt }}"
        loading="eager"
        {% if project.detail_url %}style="view-transition-name: {{ project.detail_url | slugify }}"{% endif %}
      >
      {% if screenshot_caption %}
        <figcaption>
          {{ screenshot_caption }}
        </figcaption>
      {% endif %}
    </figure>
  {% endif %}

  <section class="Project__content">
    {% markdown %}
      {{ content }}
    {% endmarkdown %}
  </section>
</article>

{% assign navigation_collection = collections.projects %}
{% if site.configuration.dev_mode %}
  {% comment %}
   Like posts, dev keyboard nav (collection-shortcuts) only follows same-origin
   links, so we skip items with `external` in front matter by using
   internal_projects.
  {% endcomment %}
  {% assign navigation_collection = collections.internal_projects %}
{% endif %}

{% render "collection_navigation.liquid",
  page: page,
  collection: navigation_collection,
  label: "project",
  dev_mode: site.configuration.dev_mode
%}
