---
layout: page
---

{% styles "pages/recipe, base/favicons" %}

<article data-link-favicons>
  <p>For {{ serves }} <span class="Fleuron" aria-hidden="true">❦</span> About {{ preparation_time }}</p>

  {{ content }}
  
  <h2>Ingredients</h2>
  <ul class="RecipeIngredients">
    {% for ingredient in ingredients %}
      <li>{{ ingredient }}</li>
    {% endfor %}
  </ul>

  <h2>Preparation</h2>
  <ol class="RecipeSteps">
    {% for step in steps %}
      <li>{{ step }}</li>
    {% endfor %}
  </ol>

  {% if notes %}
    <h2>Notes</h2>
    <ul>
      {% for note in notes %}
      <li>{{ note }}</li>
      {% endfor %}
    </ul>
  {% endif %}
</article>

{% render "collection_navigation.liquid",
  page: page,
  collection: collections.recipes,
  label: "recipe",
  dev_mode: site.configuration.dev_mode
%}
