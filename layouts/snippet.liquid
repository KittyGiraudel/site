---
layout: page
---

{% render "styles.liquid",
  inline: site.configuration.inline_assets,
  partials: "
    pages/post,
    components/code,
    components/collection-navigation
  "
%}

<article class="Post">
  {% if related %}
    {% assign related_post = '' %}
    {% for post in collections.posts %}
      {% if post.url == related %}
        {% assign related_post = post %}
      {% endif %}
    {% endfor %}

    {% if related_post %}
      <div class="Post__header">
        <p class="Post__date">
        {% if date and show_date != false %}
          {{ date | time }} <span class="Fleuron" aria-hidden="true">❦</span> 
        {% endif %}
          From <a href="{{ related }}">{{ related_post.data.title }}</a>
        </p>
      </div>
    {% endif %}
  {% endif %}

  {{ content }}
</article>

{% render "collection_navigation.liquid",
  page: page,
  collection: collections.snippets,
  label: "snippet"
%}
