{
	"title": "KittyGiraudel.com",
	"type": "module",
	"homepage": "https://kittygiraudel.com",
	"scripts": {
		"sw": "./node_modules/.bin/workbox generateSW workbox-config.cjs",
		"build": "npx @11ty/eleventy --config=eleventy.config.ts",
		"postbuild": "npm run sw",
		"start": "NODE_ENV=development npm run build --ignore-scripts -- --serve --quiet --incremental",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"test": "node --test tests/*.test.mjs"
	},
	"dependencies": {
		"@11ty/eleventy": "^3.1.2",
		"@11ty/eleventy-fetch": "^5.1.1",
		"@11ty/eleventy-img": "^6.0.4",
		"@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
		"@hapi/accept": "^6.0.3",
		"@sindresorhus/slugify": "^3.0.0",
		"11ty.ts": "^0.0.7",
		"baseline-status": "^1.1.1",
		"cheerio": "^1.2.0",
		"eleventy-plugin-footnotes": "^0.11.0",
		"emoji-regex": "^10.6.0",
		"emoji-short-name": "^2.1.0",
		"fast-xml-parser": "^5.7.1",
		"grid-rows-masonry": "^1.2.11",
		"he": "^1.2.0",
		"html-minifier-terser": "^7.2.0",
		"markdown-it": "^14.1.1",
		"netlify-plugin-cache": "^1.0.3",
		"workbox-cli": "^7.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@netlify/edge-functions": "^3.0.6",
		"@types/he": "^1.2.3",
		"@types/html-minifier-terser": "^7.0.2",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^25.6.0"
	}
}
