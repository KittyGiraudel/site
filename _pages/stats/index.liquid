---
layout: default
title: Blog Statistics
description: Vanity metrics about my writing habits on this blog over the years.
permalink: /stats/
---

{% include "styles.liquid", partials: "
  pages/stats,
  components/table,
  components/tags
" %}

{% assign stats = collections.postStats %}

{% if stats.postCount > 0 %}
  {% markdown %}
  This page highlights a few metrics about this blog: when it started, how often I post, and what
  I tend to write about. The data is computed automatically via a [custom Eleventy plugin
  ](https://github.com/KittyGiraudel/site/blob/main/_plugins/post-stats.js) and should be accurate
  at all time. Read more about [how it works](/2026/03/02/stats-page-with-11ty/).
  {% endmarkdown %}

  <section class="StatsSection">
    <h2>Overview</h2>
    <div class="StatsSection__table">
      <table>
        <tbody>
          <tr>
            <th scope="row">First post</th>
            <td>{{ stats.firstPostDate | time }}</td>
          </tr>
          <tr>
            <th scope="row">Last post</th>
            <td>{{ stats.lastPostDate | time }}</td>
          </tr>
          <tr>
            <th scope="row">Total posts</th>
            <td>{{ stats.postCount | format_number }}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="StatsSection">
    <h2>Writing frequency</h2>
    <div class="StatsSection__table">
      <table>
        <tbody>
          <tr>
            <th scope="row">Average per week</th>
            <td>{{ stats.avgPostsPerWeek | format_number }}</td>
          </tr>
          <tr>
            <th scope="row">Average per month</th>
            <td>{{ stats.avgPostsPerMonth | format_number }}</td>
          </tr>
          <tr>
            <th scope="row">Average per year</th>
            <td>{{ stats.avgPostsPerYear | format_number }}</td>
          </tr>
          <tr>
            <th scope="row">Average days between posts</th>
            <td>{{ stats.avgDaysBetweenPosts | format_number }}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="StatsSection">
    <h2>Content per post</h2>
    <div class="StatsSection__table">
      <table>
        <tbody>
          <tr>
            <th scope="row">Average characters</th>
            <td>{{ stats.avgCharacterCount | format_number }}</td>
          </tr>
          <tr>
            <th scope="row">Average words</th>
            <td>{{ stats.avgWordCount | format_number }}</td>
          </tr>
          <tr>
            <th scope="row">Average paragraphs</th>
            <td>{{ stats.avgParagraphCount | format_number }}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  {% if stats.years and stats.years.size > 0 %}
    <section class="StatsSection">
      <h2>Posts per year</h2>
      <div class="StatsSection__chart" id="stats-posts-per-year"></div>
    </section>

    <section class="StatsSection">
      <h2>Content over time</h2>
      <div class="StatsSection__chart" id="stats-content-trends"></div>
    </section>
  {% endif %}

  {% if stats.popularTags.size > 0 %}
    <section class="StatsSection StatsSection--tags">
      <h2>Tags</h2>
      {% include "tags.liquid", tags: stats.popularTags %}
    </section>
  {% endif %}
{% else %}
  <p>No posts yet — nothing to show here.</p>
{% endif %}

{% if stats.years and stats.years.size > 0 %}
  <script>
    window.__STATS_YEARS__ = [
    {% for year in stats.years %}
      {
        year: {{ year.year }},
        postCount: {{ year.postCount }},
        avgCharacterCount: {{ year.avgCharacterCount }},
        avgWordCount: {{ year.avgWordCount }},
        avgParagraphCount: {{ year.avgParagraphCount }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
    ];
  </script>
  {% include "script.liquid", partials: "utilities, stats" %}
{% endif %}
