<!DOCTYPE html>
<html lang="en">

{% include "head.liquid" %}

<body>
  {% include "skip_link.liquid" %}
  {% include "header.liquid" %}

  <main class="Main" role="main" id="main">
    <div class="container">
      {{ content }}
    </div>

    {% include "theme_button.liquid" %}
  </main>
  
  {% include "footer.liquid" %}
  {% include "script.liquid", partials: "main" %}
  {% include "script.liquid", partials: "vendors/heading-anchors", type: "module" %}
  {% if site.configuration.service_worker == true %}
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/service-worker.js', { scope: '/' })
        .then(function (registration) {
          console.log(
            '%cserviceworker:registration', 'color:green',
            'successful with scope: ' + registration.scope
          )
        })
        .catch(function (error) {
          console.error(
            '%cserviceworker:registration', 'color:red',
            'failed: ', error
          )
        })
    }
  </script>
  {% endif %}
</body>

</html>
