---
layout: default
---

{% include "styles.liquid", partials: "
  components/collection-navigation,
  components/recipe,
  components/post-date
" %}

<article class="Post">
  <p class="PostDate">For {{ serves }} <span class="Fleuron">❦</span> About {{ preparation_time }}</p>

  {% assign parts = content | split_content %}
  {{ parts[0] }}
  {% include "ad.liquid" %}
  {{ parts[1] }}
  
  <h2>Ingredients</h2>
  <ul class="RecipeIngredients">
    {% for ingredient in ingredients %}
      <li>{{ ingredient }}</li>
    {% endfor %}
  </ul>

  <h2>Preparation</h2>
  <ol class="RecipeSteps">
    {% for step in steps %}
      <li>{{ step }}</li>
    {% endfor %}
  </ol>

  {% if notes %}
    <h2>Notes</h2>
    <ul>
      {% for note in notes %}
      <li>{{ note }}</li>
      {% endfor %}
    </ul>
  {% endif %}
</article>

{% include "collection_navigation.liquid",
  page: page,
  collection: collections.recipes,
  label: "recipe"
%}
