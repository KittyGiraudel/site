---
layout: default
---

{% include "styles.html", partials: "
  components/code,
  components/collection-navigation,
  components/post-date
" %}

<article class="Post">
  {% if related %}
    {% assign related_post = '' %}
    {% for post in collections.posts %}
      {% if post.url == related %}
        {% assign related_post = post %}
      {% endif %}
    {% endfor %}

    <p class="PostDate">
      {{ related_post.date | time }} <span class="Fleuret">❦</span> From <a href="{{ related }}">{{ related_post.data.title }}</a>
    </p>
  {% endif %}

  {% assign parts = content | split: "</p>" %}
  {{ parts | first }}</p>

  {% include "ad.html" %}

  {% for part in parts offset: 1 %}
    {{ part }}{% unless forloop.last %}</p>{% endunless %}
  {% endfor %}
</article>

{% include "collection_navigation.html",
  page: page,
  collection: collections.snippets,
  name: "snippet"
%}
