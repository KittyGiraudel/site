<div id="carbon-viz">
{% capture demo_styles -%}
{%- include "demos/carbon/styles.css" -%}
{%- endcapture %}
<style>{{ demo_styles }}</style>

<section class="chart-card">
  <div class="chart-header">
    <div>
      <div class="chart-title">Monthly payouts (USD)</div>
      <div class="chart-subtitle" id="rangeLabel"></div>
    </div>
    <div>
      <div class="range-toggle" aria-label="Time range" role="radiogroup">
        <button type="button" data-range="all" class="is-active">All</button>
        <button type="button" data-range="5y">Last 5y</button>
        <button type="button" data-range="3y">Last 3y</button>
        <button type="button" data-range="2y">Last 2y</button>
        <button type="button" data-range="1y">Last 1y</button>
      </div>
      <label class="estimates-toggle" id="estimatesWrapper">
        <input type="checkbox" id="estimatesToggle">
        <span>Include extrapolated history back to 2013</span>
      </label>
    </div>
  </div>
  <canvas id="payoutsChart" aria-label="Monthly Carbon payouts for giraudel.com" role="img"></canvas>
</section>

<section class="summary-card">
  <div class="summary-grid">
    <div class="summary-item">
      <div class="summary-label">Total for period</div>
      <div class="summary-value" id="totalValue">$0.00</div>
    </div>
    <div class="summary-item">
      <div class="summary-label">Months tracked</div>
      <div class="summary-value" id="monthsValue">0</div>
    </div>
    <div class="summary-item">
      <div class="summary-label">Best month</div>
      <div class="summary-value" id="bestMonthValue">–</div>
    </div>
    <div class="summary-item">
      <div class="summary-label">Average / month</div>
      <div class="summary-value" id="avgValue">$0.00</div>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const postsPerMonth = {{ collections.postStats[0].months | json }};
{%- include "demos/carbon/data.js" -%}
{%- include "demos/carbon/script.js" -%}
</script>
</div>