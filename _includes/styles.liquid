{% comment %}
  Required:
  - partials: The partials to render
  - inline: Whether to inline the styles
{% endcomment %}

{% ensure partials, "Required value 'partials' is missing in styles.liquid" %}
{% ensure inline, "Required value 'inline' is missing in styles.liquid" %}

{% assign paths = partials | split: "," %}

{%- if inline -%}
  {%- capture css -%}
    {% for path in paths -%}{%- include "../assets/css/{{ path | strip }}.css" -%}{%- endfor %}
  {%- endcapture -%}

  <style data-helmet>{{ css }}</style>
{%- else -%}
  {%- for path in paths %}<link data-helmet rel="stylesheet" href="/assets/css/{{ path | strip }}.css" />{% endfor %}
{%- endif %}
