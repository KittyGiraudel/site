{% if partials -%}
  {% assign paths = partials | split: "," %}

  {%- if site.configuration.inline_styles == true -%}
    {%- capture css -%}
      {% for path in paths -%}{%- include "../assets/css/{{ path | strip }}.css" -%}{%- endfor %}
    {%- endcapture -%}

    <style data-helmet>{{ css }}</style>
  {%- else -%}
    {%- for path in paths %}<link data-helmet rel="stylesheet" href="/assets/css/{{ path | strip }}.css" />{% endfor %}
  {%- endif %}
{% endif %}
