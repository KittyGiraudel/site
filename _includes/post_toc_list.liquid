{% if items and items.size > 0 %}
  <ol class="PostToc__list{% unless root %} PostToc__list--sublist{% endunless %}">
    {% for item in items %}
      <li class="PostToc__item PostToc__item--level{{ item.level }}">
        <a href="#{{ item.id }}">{{ item.text }}</a>

        {% if item.children and item.children.size > 0 %}
          {% include "post_toc_list.liquid", items: item.children, root: false %}
        {% endif %}
      </li>
    {% endfor %}
  </ol>
{% endif %}

