{% assign page_url = page.url | prepend: site.url %}
{% assign page_description = description | default: site.description | strip_html | strip_newlines |
truncate: 200 %}

<head prefix="og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article:
http://ogp.me/ns/article#">
  <!-- Global stuff -->
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#dd7eb4">
  <meta name="generator" content="{{ eleventy.generator }}">

  <!-- Page specific content -->
  <title>{% if title %}{{ title }} | {{ site.author }}{% else %}{{ site.author }}{% endif %}</title>
  <meta name="description" content="{{ page_description | emoji_to_text | escape }}">
  {% if keywords %}
    <meta name="keywords" content="{{ keywords | join: ',' }}" />
  {% elsif tags %}
    <meta name="keywords" content="{{ tags | join: ',' }}" />
  {% endif %}
  <meta name="author" content="{{ guest | default: site.author }}">
  <link rel="canonical" href="{{ page_url }}">

  <!-- Robots & indexing -->
  <meta name="robots" content="index,follow">

  <!-- Styles -->
  {% include "styles.liquid", partials: "
    base/base,
    base/helpers,
    layout/header,
    layout/footer,
    layout/main,
    layout/navigation,
    components/abbr,
    components/callout,
    components/skip-link,
    components/theme-button,
    components/title,
    base/shame
  " %}

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="{{ site.author }}"
    href="{{ '/rss/index.xml' | prepend: site.url }}" />

  <!-- Favicon -->
  <link rel="shortcut icon" href="/assets/images/favicon.jpg">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <!-- Manifest -->
  <link rel="manifest" href="/manifest.json">

  <!-- Open Graph data -->
  <meta property="og:title" content="{{ title | default: site.author }}" />
  <meta property="og:type" content="{% if layout == 'post' %}article{% else %}website{% endif %}" />
  <meta property="og:url" content="{{ page_url }}" />
  <meta property="og:description" content="{{ page_description | emoji_to_text | escape }}" />
  <meta property="og:site_name" content="kittygiraudel.com" />

  <!-- Twitter Card data -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:creator" content="@KittyGiraudel">
  <meta name="twitter:description" content="{{ page_description | emoji_to_text | escape }}">
  <meta name="twitter:domain" content="kittygiraudel.com">
  <meta name="twitter:image" content="https://kittygiraudel.com/assets/images/favicon-192.jpg">
  <meta name="twitter:site" content="@KittyGiraudel">
  <meta name="twitter:title" content="{{ title | default: site.author }}">
</head>