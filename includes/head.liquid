{% comment %}
  Required:
  - site_url: The URL of the site
  - site_author: The author of the site
  - page_url: The URL of the page
  - page_author: The author of the page
  - page_description: The description of the page
  - inline_assets: Whether to inline the styles and scripts
  - title: The title of the page
  Optional:
  - layout: The layout of the page
  - page_image: The image of the page
  - page_date: The date of the page
  - page_update_date: The update date of the page
  - tags: Tag/keyword list for the page
  - generator: The generator of the page
  - site_same_as: List of profile URLs for Person schema
{% endcomment %}
 
{% ensure inline_assets, "Required value 'inline_assets' is missing in head.liquid" %}
{% ensure page_author, "Required value 'page_author' is missing in head.liquid" %}
{% ensure page_description, "Required value 'page_description' is missing in head.liquid" %}
{% ensure page_url, "Required value 'page_url' is missing in head.liquid" %}
{% ensure site_author, "Required value 'site_author' is missing in head.liquid" %}
{% ensure site_url, "Required value 'site_url' is missing in head.liquid" %}
{% ensure title, "Required value 'title' is missing in head.liquid" %}
{% if page_image contains '://' %}
  {% assign page_image_url = page_image %}
{% else %}
  {% assign page_image_url = page_image | prepend: site_url %}
{% endif %}

<head prefix="og: http://ogp.me/ns# fb: http://ogp.me/ns/fb# article:
http://ogp.me/ns/article#">
  <!-- Global stuff -->
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#dd7eb4">
  {% if generator %}
    <meta name="generator" content="{{ generator }}">
  {% endif %}

  <!-- Page specific content -->
  <title>{% if title %}{{ title }} | {{ site_author }}{% else %}{{ site_author }}{% endif %}</title>
  <meta name="description" content="{{ page_description }}">
  {% if tags %}
    <meta name="keywords" content="{{ tags | join: ',' }}" />
  {% endif %}
  <meta name="author" content="{{ page_author }}">
  <link rel="canonical" href="{{ page_url }}">

  <!-- Robots & indexing -->
  <meta name="robots" content="index,follow">

  <!-- Styles -->
  {% render "styles.liquid",
    inline: inline_assets,
    partials: "
      base/base,
      base/helpers,
      layout/header,
      layout/footer,
      layout/main,
      layout/navigation,
      components/abbr,
      components/callout,
      components/skip-link,
      components/theme-button,
      components/title,
      base/shame
    "
  %}

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="{{ site_author }}"
    href="{{ '/rss/index.xml' | prepend: site_url }}" />

  <!-- Favicon -->
  <link rel="shortcut icon" href="/assets/images/favicon.png">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <!-- Manifest -->
  <link rel="manifest" href="/manifest.json">

  <!-- Open Graph data -->
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:type" content="{% if layout == 'post' %}article{% else %}website{% endif %}" />
  <meta property="og:url" content="{{ page_url }}" />
  <meta property="og:description" content="{{ page_description }}" />
  <meta property="og:site_name" content="kittygiraudel.com" />
  <meta property="og:image" content="{{ page_image_url }}">

  {% if layout == 'post' %}
    <!-- Article tags -->
    <meta property="article:author" content="{{ page_author }}" />
    {% if page_date %}
      <meta property="article:published_time" content="{{ page_date | date_to_rfc3339 }}" />
    {% endif %}
    {% if page_update_date %}
      <meta property="article:modified_time" content="{{ page_update_date | date_to_rfc3339 }}" /> 
    {% endif %}
    {% for tag in tags %}
      <meta property="article:tag" content="{{ tag }}" />
    {% endfor %}
  {% endif %}

  <!-- Twitter Card data -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:creator" content="@KittyGiraudel">
  <meta name="twitter:description" content="{{ page_description }}">
  <meta name="twitter:domain" content="kittygiraudel.com">
  <meta name="twitter:image" content="{{ page_image_url }}">
  <meta name="twitter:site" content="@KittyGiraudel">
  <meta name="twitter:title" content="{{ title }}">

  <!-- Structured data -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ site_author | jsonify }},
      "url": {{ site_url | jsonify }},
      "description": {{ page_description | jsonify }}
    }
  </script>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": {{ site_author | jsonify }},
      "url": {{ site_url | jsonify }}{% if site_same_as and site_same_as.size > 0 %},
      "sameAs": {{ site_same_as | jsonify }}{% endif %}
    }
  </script>
  {% if layout == 'post' %}
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": {{ title | jsonify }},
        "description": {{ page_description | jsonify }},
        "author": {
          "@type": "Person",
          "name": {{ page_author | jsonify }}
        },
        "publisher": {
          "@type": "Person",
          "name": {{ site_author | jsonify }},
          "url": {{ site_url | jsonify }}
        },
        {% if page_date -%}
        "datePublished": {{ page_date | date_to_rfc3339 | jsonify }},
        {%- endif %}
        {% if page_update_date -%}
        "dateModified": {{ page_update_date | date_to_rfc3339 | jsonify }},
        {%- endif %}
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": {{ page_url | jsonify }}
        },
        "url": {{ page_url | jsonify }},
        "image": {{ page_image_url | jsonify }}
      }
    </script>
  {% endif %}
  
  {% render "script.liquid",
    inline: inline_assets,
    partials: "theme"
  %}
</head>
