{% comment %}
  Required:
  - created_at: The original creation/published date
  Optional:
  - updated_at: Last updated date of the page
  - reading_time: The reading time of the page
  - author: The author of the page
{% endcomment %}

{% ensure created_at, "Required value 'created_at' is missing in metadata.liquid" %}

{% capture rest %}
{%- if author %}, by <span itemprop="author" id="page-author">{{ author }}</span>{% endif %}
<span class="Fleuron" aria-hidden="true">❦</span> {% if reading_time %}<span itemprop="timeRequired" id="page-reading-time" title="Estimated read time">{{ reading_time.display }}</span>{% endif %}
{% endcapture %}

<p class="Metadata">
  {% if not updated_at %}
    {{ created_at | time: "datePublished", "page-date-published" }}
    {{ rest }}
  {% else %}
    {% assign created_date = created_at | date: "%Y-%m-%d" %}
    {% assign updated_date = updated_at | date: "%Y-%m-%d" %}
    {% assign was_updated = updated_date != created_date %}
  
    {% if was_updated %}
      {{ created_at | time: "datePublished", "page-date-published" }}{{ rest }}
      <span class="Metadata__updated">Edited on {{ updated_at | time: "dateModified", "page-date-modified" }}</span>
    {% else %}
      {{ created_at | time: "datePublished", "page-date-published" }}{{ rest }}
    {%  endif  %}
  {% endif %}
</p>
