{% comment %}
  Required:
  - edits: The edits to render
{% endcomment %}

{% ensure edits, "Required value 'edits' is missing in post_edits.liquid" %}

<div class="Callout PostEdits" id="post-edits">
  <h2 class="PostEdits__title">Noteworthy edits</h2>
  {% for edit in edits %}
    <p>
      <span class="PostEdits__date">{{ edit.date | time }}:</span>
      {% markdown "inline" %}{{ edit.md }}{% endmarkdown %}
    </p>
  {% endfor %}
</div>
