{% comment %}
  Required:
  - title: The title of the page
  Optional:
  - lang: The language of the page
  - with_title_break: Whether to break the title
{% endcomment %}
 
{% ensure title, "Required value 'title' is missing in header.liquid" %}

<header class="Header" role="banner">
  <div class="Container">
    {% render "title.liquid", title: title, lang: lang, with_title_break: with_title_break %}
  </div>
</header>
