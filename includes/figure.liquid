{% comment %}
  Required:
  - src: The source of the image
  - caption: The caption of the figure
  Optional:
  - alt: The alt text of the image
  - lazy: Whether to load the image lazily (default: true). When false, outputs
    loading="eager" so the image transform default (lazy) does not apply.
{% endcomment %}

{% ensure src, "Required value 'src' is missing in figure.liquid" %}
{% ensure caption, "Required value 'caption' is missing in figure.liquid" %}

{% assign alt = alt | default: caption %}
{% assign lazy = lazy | default: true %}

{% styles "components/figure" %}

<figure class="Figure">
  <img src="{{ src }}" alt="{{ alt }}" loading="{% if lazy %}lazy{% else %}eager{% endif %}">
  <figcaption>{{ caption }}</figcaption>
</figure>