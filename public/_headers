/*
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), fullscreen=(self)

/
  Link: </rss/index.xml>; rel="alternate"; type="application/atom+xml", </blog/search/data.json>; rel="describedby"; type="application/json"

/assets/images/*
  cache-control: public
  cache-control: max-age=86400

/.well-known/traffic-advice
  Content-Type: application/trafficadvice+json; charset=utf-8

/*.md
  X-Robots-Tag: noindex
  Content-Type: text/markdown; charset=utf-8