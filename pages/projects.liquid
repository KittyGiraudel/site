---
layout: page
title: Open-Source Projects
description: 'A list of all of Kitty Giraudel’s noteworthy open-sourced projects, all hosted on GitHub.'
keywords:
  - projects
  - open-source
  - github
permalink: /projects/
---

{% assign projects_list_url = page.url | prepend: site.url %}
<script type="application/ld+json" data-helmet>{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ title | jsonify }},
  "description": {{ description | strip_html | strip_newlines | truncate: 200 | jsonify }},
  "url": {{ projects_list_url | jsonify }},
  "numberOfItems": {{ collections.projects.size }},
  "itemListElement": [
    {% for p in collections.projects %}
    {
      "@type": "ListItem",
      "position": {{ forloop.index }},
      "item": {
        "@type": "WebPage",
        "@id": {{ p.url | prepend: site.url | jsonify }},
        "name": {{ p.data.title | jsonify }}
      }
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}</script>

{% render "styles.liquid",
  inline: site.configuration.inline_assets,
  partials: "
    components/card-grid,
    components/card,
    components/tags
  "
%}

