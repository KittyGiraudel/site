---
permalink: /blog/search/data.json
eleventyExcludeFromCollections: true
---
{% assign arr = '' | split: '' %}
[
  {% for post in collections.posts %}
    {
      "title"    : {{ post.data.title | jsonify }},
      "lang"     : {{ post.data.lang | default: 'en' | jsonify }},
      "tags"     : {{ post.data.tags | default: arr | jsonify }},
      "url"      : {% if post.data.external %}{{ post.data.external.url | jsonify }}{% else %}{{ post.url | jsonify }}{% endif %},
      "date"     : {{ post.date | date: '%B %d, %Y' | jsonify }},
      "guest"    : {% if post.data.guest %}{{ post.data.guest | prepend: ' by ' | jsonify }}{% else %}"\u200b"{% endif %},
      "external" : {% if post.data.external %}{{ post.data.external.host | prepend: ' at ' | jsonify }}{% else %}"\u200b"{% endif %}
    } {% unless forloop.last %},{% endunless %}
  {% endfor %}
]
