---
layout: default
title: Blog Statistics
description: Vanity metrics about my writing habits on this blog over the years.
permalink: /stats/
---
{% include 'styles.html', partials: 'pages/stats, components/table, components/tags' %}

{% assign stats = collections.postStats %}

{% if stats.postCount > 0 %}
  {% markdown %}
  This page highlights a few metrics about this blog: when it started, how often I post, and what I tend to write about.
  The data is computed automatically via a custom Eleventy plugin and should be accurate at all time.
  {% endmarkdown %}

  <heading-anchors selector="h2" content="§">
    <section class="StatsSection">
      <h2>Overview</h2>
      <div class="StatsSection__table">
        <table>
          <tbody>
            <tr>
              <th scope="row">First post</th>
              <td>{{ stats.firstPostDate | time }}</td>
            </tr>
            <tr>
              <th scope="row">Last post</th>
              <td>{{ stats.lastPostDate | time }}</td>
            </tr>
            <tr>
              <th scope="row">Total posts</th>
              <td>{{ stats.postCount }}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="StatsSection">
      <h2>Writing frequency</h2>
      <div class="StatsSection__table">
        <table>
          <tbody>
            <tr>
              <th scope="row">Average per week</th>
              <td>{{ stats.avgPostsPerWeek }}</td>
            </tr>
            <tr>
              <th scope="row">Average per month</th>
              <td>{{ stats.avgPostsPerMonth }}</td>
            </tr>
            <tr>
              <th scope="row">Average per year</th>
              <td>{{ stats.avgPostsPerYear }}</td>
            </tr>
            <tr>
              <th scope="row">Average days between posts</th>
              <td>{{ stats.avgDaysBetweenPosts }}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="StatsSection">
      <h2>Content per post</h2>
      <div class="StatsSection__table">
        <table>
          <tbody>
            <tr>
              <th scope="row">Average characters</th>
              <td>{{ stats.avgCharacterCount }}</td>
            </tr>
            <tr>
              <th scope="row">Average words</th>
              <td>{{ stats.avgWordCount }}</td>
            </tr>
            <tr>
              <th scope="row">Average paragraphs</th>
              <td>{{ stats.avgParagraphCount }}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    {% if stats.popularTags.size > 0 %}
      <section class="StatsSection StatsSection--tags">
        <h2>Tags</h2>
        <div>
          {% include 'tags.html', tags: stats.popularTags %}
        </div>
      </section>
    {% endif %}
  </heading-anchors>
{% else %}
  <p>No posts yet — nothing to show here.</p>
{% endif %}
